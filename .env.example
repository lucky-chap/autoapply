# Auth0 Configuration (v4 SDK)
AUTH0_SECRET=                 # Generate with `openssl rand -hex 32`
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Convex Configuration
NEXT_PUBLIC_CONVEX_URL=       # From `npx convex dev`
NEXT_PUBLIC_CONVEX_SITE_URL=  # Same deployment but with .convex.site domain (for HTTP actions)
CONVEX_DEPLOY_KEY=            # For production deployments
CONVEX_API_SECRET=            # Shared secret for server-to-server Convex HTTP actions (generate with `openssl rand -hex 32`)

# AI & APIs
GLM_API_KEY=                  # For resume parsing and cover letter generation

# Telegram Bot - One time setup, can be removed later
# but must be set in convex environment
TELEGRAM_BOT_TOKEN=          # From @BotFather on Telegram
TELEGRAM_WEBHOOK_SECRET=     # Generate with `openssl rand -hex 32`


# Encryption
ENCRYPTION_SECRET=   # Generate with `openssl rand -hex 32`